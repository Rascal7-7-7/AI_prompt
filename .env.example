# .env.example — コピーして .env を作成してください（.env は git 管理外）
# cp .env.example .env
#
# 注意: ファイル名は .env.local ではなく .env を使ってください。
# Prisma CLI は .env のみ自動読込し、.env.local は読みません。
# .env なら Next.js と Prisma の両方が読めます。

# 本アプリは AI API キーを使用しません（サンドボックス/比較は静的サンプル表示）。
# 必要なのは DB 接続のみです。

# Database（Neon PostgreSQL）
# Neon ダッシュボードの "Connection string"（pooled 推奨）を貼り付け
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# アプリ設定
NEXT_PUBLIC_APP_URL=http://localhost:3000
